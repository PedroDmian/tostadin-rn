{
  "name": "tostadin-rn",
  "version": "0.0.3",
  "description": "Tostadín – A beautiful toast component for React Native.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace tostadin-rn-example",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "test": "jest",
    "release": "release-it",
    "release:minor": "release-it minor --ci",
    "release:patch": "release-it patch --ci"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "toast",
    "tostadin",
    "tostadin-rn",
    "notifications",
    "alert",
    "ui",
    "component",
    "react-native-component",
    "message",
    "popup",
    "snackbar",
    "banner",
    "overlay",
    "feedback",
    "customizable",
    "typescript",
    "svg",
    "lucide",
    "animation",
    "status-bar",
    "in-app-notification",
    "alert-view",
    "toast-notifications",
    "toast-messages",
    "react-native-library",
    "native-ui",
    "popover",
    "dropdown-alert",
    "top-alert",
    "bottom-alert",
    "notistack",
    "sonner",
    "react-hot-toast",
    "modern-ui",
    "accessible",
    "a11y",
    "gestures",
    "touch-events",
    "clean-architecture",
    "ddd",
    "use-toast",
    "toast-provider",
    "toast-hook",
    "reanimated",
    "notification-system",
    "mobile-ui",
    "cross-platform",
    "javascript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PedroDmian/tostadin-rn.git"
  },
  "author": "Damian Palomo <pedrodamian411@gmail.com> (https://github.com/PedroDmian)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/PedroDmian/tostadin-rn/issues"
  },
  "homepage": "https://github.com/PedroDmian/tostadin-rn#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@react-native/babel-preset": "0.83.0",
    "@react-native/eslint-config": "0.83.0",
    "@release-it/conventional-changelog": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.12",
    "commitlint": "^19.8.1",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "del-cli": "^6.0.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "lefthook": "^2.0.3",
    "lucide-react-native": "*",
    "prettier": "^2.8.8",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-builder-bob": "^0.40.18",
    "react-native-svg": "*",
    "release-it": "^19.0.4",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "lucide-react-native": "*",
    "react": "*",
    "react-native": "*",
    "react-native-svg": "*"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "conventionalcommits",
        "infile": "CHANGELOG.md"
      }
    }
  },
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "tools": [
      "eslint",
      "jest",
      "lefthook",
      "release-it"
    ],
    "version": "0.57.2"
  }
}
